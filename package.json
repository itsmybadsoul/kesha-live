{
  "name": "crypto-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "next build && npx @cloudflare/next-on-pages --skip-build && node generate-routes.mjs",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "npm run build:pages",
    "deploy": "npm run build:pages && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "15.4.11",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "41.0.0",
    "wrangler": "^3.109.2"
  }
}
